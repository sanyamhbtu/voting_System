# ─────────────────────────────────────────────────────────────
# Backend environment variables — copy to `.env` and fill in.
# ─────────────────────────────────────────────────────────────

# Server
PORT=3000
# Comma-free single origin of the deployed frontend (used for CORS).
FRONTEND_URL=http://localhost:5173

# Auth
JWT_SECRET_KEY=replace-with-a-long-random-string

# MongoDB (free tier: https://www.mongodb.com/atlas)
# NOTE: the variable name is MONOGDB_URL (matches the code's spelling).
MONOGDB_URL=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/voting

# Blockchain (free testnet RPC, e.g. https://dashboard.alchemy.com or a public RPC)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-key
META_PRIVATE_KEY=0xyour_admin_wallet_private_key
CONTRACT_ADDRESS=0xyour_deployed_voting_contract_address
MNEOMONIC="twelve word seed phrase used to derive per-voter wallets"

# Google Cloud (Vision OCR + Storage)
# Option A (recommended for free hosts): paste the entire service-account JSON on ONE line:
# GCP_CREDENTIALS_JSON={"type":"service_account","project_id":"...", ... }
GCP_CREDENTIALS_JSON=
# Option B (local dev): path to the key file instead of the inline JSON above.
GOOGLE_APPLICATION_CREDENTIALS=src/skilled-circle-448817-d1-e3457c9445ad.json
# Storage bucket name
GCS_BUCKET=votingbuck
