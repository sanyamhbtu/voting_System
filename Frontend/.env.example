# ─────────────────────────────────────────────────────────────
# Frontend environment variables — copy to `.env` and fill in.
# Vite only exposes variables prefixed with VITE_.
# ─────────────────────────────────────────────────────────────

# Backend API + WebSocket base URLs
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000

# Firebase (phone OTP auth) — web config is public-safe but keep it configurable.
# Restrict the key by domain in the Firebase console for production.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
